  Main configuration page.
  - The "payline" (credentials) tab uses the new Symfony form stack.
  - All other tabs embed legacy HelperForm HTML during the progressive migration.
#}

{% extends '@PrestaShop/Admin/layout.html.twig' %}

{# Apply the PS UI kit theme to the Symfony form (credentials tab) #}
{#{% form_theme paylineGeneralForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}#}

{% block content %}
    {{ form_start(paylineConfigurationForm) }}
    <div class="card">
        <h3 class="card-header">
            <i class="material-icons">vpn_key</i> {{ 'Monext configuration'|trans({}, 'Modules.Payline.Admin') }}
        </h3>
        <div class="card-body">
            <div class="form-wrapper">
                {{ form_widget(paylineConfigurationForm) }}
            </div>
        </div>
        <div class="card-footer">
            <div class="d-flex justify-content-end">
                <button class="btn btn-primary float-right" id="save-button">
                    {{ 'Save'|trans({}, 'Admin.Actions') }}
                </button>
            </div>
        </div>
    </div>
    {{ form_end(paylineConfigurationForm) }}
{% endblock %}
